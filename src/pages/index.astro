      </section>

      <section id="publications" class="academic-section">
        <h2><span class="section-emoji" aria-hidden="true">✍️</span><span class="lang-en">Publications & Writing</span><span class="lang-zh">发表与写作</span></h2>
        <div class="entry-list">
          {publications.map((item) => (
            <article class="entry">
              <h3>
                <span class="lang-en">{item.title}</span><span class="lang-zh">{item.titleZh}</span>
                {(item.href || item.pdf) && (
                  <span class="entry-inline-meta">
                    {item.href && <a href={item.href} target="_blank" rel="noopener">[Link]</a>}
                    {item.pdf && <a href={item.pdf} target="_blank" rel="noopener">[PDF]</a>}
                  </span>
                )}
              </h3>
              <p class="entry-meta">
                <span class="lang-en">{item.venue}</span><span class="lang-zh">{item.venueZh}</span> · {item.year}
              </p>
              <p><span class="lang-en">{item.description}</span><span class="lang-zh">{item.descriptionZh}</span></p>
            </article>
          ))}
        </div>
      </section>

      <section id="projects" class="academic-section">
        <h2><span class="section-emoji" aria-hidden="true">🛠️</span><span class="lang-en">Selected Projects</span><span class="lang-zh">项目精选</span></h2>
        <div class="entry-list">
          {projects.map((project) => (
            <article class="entry">
              <h3>
                <span class="lang-en">{project.title}</span><span class="lang-zh">{project.titleZh}</span>
                {project.href && (
                  <span class="entry-inline-meta">
                    <a href={project.href} target={project.href.startsWith('http') ? '_blank' : undefined} rel={project.href.startsWith('http') ? 'noopener' : undefined}>[Link]</a>
                  </span>
                )}
              </h3>
              <p>
                <span aria-hidden="true">▸ </span><strong>TL;DR:</strong>
                <span class="lang-en"> {project.description}</span><span class="lang-zh"> {project.descriptionZh}</span>
              </p>
            </article>
          ))}
        </div>
      </section>

      <section id="contact" class="academic-section">
        <h2><span class="section-emoji" aria-hidden="true">📬</span><span class="lang-en">Contact</span><span class="lang-zh">联系方式</span></h2>
        <p class="lang-en">
          Feel free to reach me at <a href="mailto:jq_li25@stu.pku.edu.cn">jq_li25@stu.pku.edu.cn</a>
          or through <a href="https://github.com/Silver-Moon-Over-Snow" target="_blank" rel="noopener">GitHub</a>.
        </p>
        <p class="lang-zh">
          欢迎通过 <a href="mailto:jq_li25@stu.pku.edu.cn">jq_li25@stu.pku.edu.cn</a>
          或 <a href="https://github.com/Silver-Moon-Over-Snow" target="_blank" rel="noopener">GitHub</a> 联系我。
        </p>
      </section>
    </div>
  </main>

  <button class="back-to-top" aria-label="回到顶部">↑</button>
</BaseLayout>
