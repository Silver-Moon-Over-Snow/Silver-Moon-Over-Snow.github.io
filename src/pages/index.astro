---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const notes = (await getCollection('notes')).sort((a, b) => {
  const left = a.data.date?.getTime() ?? 0;
  const right = b.data.date?.getTime() ?? 0;
  return right - left;
});
---

<BaseLayout>
  <nav class="nav" aria-label="主导航">
    <div class="nav-inner">
      <a href="#home" class="nav-logo" aria-label="回到首页">C</a>
      <ul class="nav-links">
        <li><a href="#about">关于</a></li>
        <li><a href="#education">履历</a></li>
        <li><a href="#now">动态</a></li>
        <li><a href="#skills">技能</a></li>
        <li><a href="#projects">项目</a></li>
        <li><a href="#links">入口</a></li>
        <li><a href="#notes">笔记</a></li>
        <li><a href="#contact">联系</a></li>
      </ul>
      <button class="theme-toggle" type="button" aria-label="切换深色模式">
        <span class="theme-toggle-icon" aria-hidden="true"></span>
      </button>
    </div>
  </nav>

  <main>
    <section id="home" class="hero">
      <div class="hero-content">
        <p class="hero-greeting">你好，我是</p>
        <h1 class="hero-name">Cheerly</h1>
        <p class="hero-location">China / Beijing</p>
        <p class="hero-tagline">以代码编织星空，用匠心雕琢产品</p>
        <p class="hero-sub">Silver-Moon-Over-Snow</p>
        <div class="hero-actions">
          <a href="https://github.com/Silver-Moon-Over-Snow" target="_blank" rel="noopener">GitHub</a>
          <a href="mailto:jq_li25@stu.pku.edu.cn">Email</a>
        </div>
      </div>
    </section>

    <section id="about" class="about">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">关于我</span>
          <span class="section-title-en">About Me</span>
        </h2>
        <div class="about-content">
          <div class="about-avatar">
            <div class="avatar-placeholder" aria-hidden="true">C</div>
          </div>
          <div class="about-text">
            <p>你好！我是 Cheerly，目前就读于 <strong>北京大学</strong>。</p>
            <p>我相信代码不仅是逻辑的堆砌，更是一种表达与创造的方式。热衷于将复杂的问题转化为简洁优雅的解决方案，在技术与人之间架起桥梁。</p>
            <p>工作之余，喜欢探索新领域、阅读，以及仰望星空。Silver-Moon-Over-Snow 这个名字，正源于对静谧与美好的向往。</p>
          </div>
        </div>
      </div>
    </section>

    <section id="education" class="education">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">教育履历</span>
          <span class="section-title-en">Education</span>
        </h2>
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-card">
              <div class="timeline-emblem" aria-hidden="true">
                <img class="timeline-emblem-img" src="/images/pku_emblem.png" alt="" width="56" height="56" loading="lazy" />
              </div>
              <div class="timeline-card-content">
                <div class="timeline-badge">在读</div>
                <h3>北京大学</h3>
                <p class="timeline-sub">Peking University</p>
                <p>数学与计算机交叉领域，注重扎实的理论基础与工程实践并重。</p>
              </div>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-card">
              <div class="timeline-emblem" aria-hidden="true">
                <img class="timeline-emblem-img" src="/images/changjun-emblem.png" alt="" width="56" height="56" loading="lazy" />
              </div>
              <div class="timeline-card-content">
                <div class="timeline-badge">毕业</div>
                <h3>长郡中学</h3>
                <p class="timeline-sub">Changjun High School</p>
                <p>百年名校，朴实沉毅。在这里度过了充实而难忘的中学时光。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="now" class="now">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">近况</span>
          <span class="section-title-en">Now</span>
        </h2>
        <div class="now-grid">
          <article class="now-card">
            <p class="now-meta">Focus</p>
            <h3>数学与计算机交叉学习</h3>
            <p>持续打磨数学基础、算法能力与工程实践，把抽象理论转化为可运行、可解释的作品。</p>
          </article>
          <article class="now-card">
            <p class="now-meta">Reading</p>
            <h3>技术、数学与人文阅读</h3>
            <p>在专业学习之外保持广泛阅读，用更长的时间尺度理解工具、知识和表达。</p>
          </article>
          <article class="now-card">
            <p class="now-meta">Interest</p>
            <h3>星空、符号与创造</h3>
            <p>喜欢天文与数学里的秩序感，也喜欢把这种秩序感落实到简洁、清晰的网页与程序里。</p>
          </article>
        </div>
      </div>
    </section>

    <section id="skills" class="skills">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">技能栏</span>
          <span class="section-title-en">Skills</span>
        </h2>
        <div class="skills-grid">
          {[
            ['∑', '数学基础', ['数学分析', '高等代数', '概率统计', '微分方程']],
            ['🖥', '计算机科学', ['并行程序设计', '数据结构', '算法设计', '计算机组成']],
            ['⟨⟩', '编程语言', ['C / C++', 'Python', 'HTML / CSS', 'JavaScript']],
            ['⚙', '工具与平台', ['Git', 'Linux', 'VS Code', 'GitHub']]
          ].map(([icon, title, tags]) => (
            <div class="skill-card">
              <div class="skill-icon" aria-hidden="true">{icon}</div>
              <h3>{title}</h3>
              <div class="skill-tags">{(tags as string[]).map((tag) => <span>{tag}</span>)}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="projects">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">项目展示</span>
          <span class="section-title-en">Projects</span>
        </h2>
        <div class="projects-grid">
          <a href="https://github.com/Silver-Moon-Over-Snow/my_web_project" class="project-card" target="_blank" rel="noopener">
            <div class="project-card-top">
              <h3>个人主页</h3>
              <p>从纯 HTML/CSS 迁移到 Astro 的个人主页，展示个人信息、技能、项目与 Markdown 笔记。</p>
            </div>
            <div class="project-card-bottom">
              <span class="project-tag">Astro</span>
              <span class="project-tag">Markdown</span>
              <span class="project-tag">GitHub Pages</span>
            </div>
          </a>
          <div class="project-card">
            <div class="project-card-top">
              <h3>兴趣爱好</h3>
              <p>仰望星空、阅读、探索数学之美。相信简洁与优雅的力量，在代码与符号之间寻找诗意。</p>
            </div>
            <div class="project-card-bottom">
              <span class="project-tag">阅读</span>
              <span class="project-tag">天文</span>
              <span class="project-tag">数学</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="links" class="links">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">入口</span>
          <span class="section-title-en">Links</span>
        </h2>
        <div class="link-list">
          <a href="https://github.com/Silver-Moon-Over-Snow" target="_blank" rel="noopener">
            <span>GitHub</span>
            <small>代码、项目与练习</small>
          </a>
          <a href="mailto:jq_li25@stu.pku.edu.cn">
            <span>Email</span>
            <small>交流与联系</small>
          </a>
          <a href="https://github.com/Silver-Moon-Over-Snow/my_web_project" target="_blank" rel="noopener">
            <span>Homepage Repository</span>
            <small>这个站点的源码</small>
          </a>
        </div>
      </div>
    </section>

    <section id="notes" class="notes">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">笔记</span>
          <span class="section-title-en">Notes</span>
        </h2>
        <div class="note-list">
          {notes.map((note) => (
            <a href={`/notes/${note.slug}/`}>
              <span>{note.data.title}</span>
              <small>{note.data.description} · {note.data.tags.join(' / ')}</small>
            </a>
          ))}
        </div>
        <div class="section-more">
          <a href="/notes/">查看全部笔记</a>
        </div>
      </div>
    </section>

    <section id="contact" class="contact">
      <div class="container">
        <h2 class="section-title">
          <span class="section-title-cn">联系方式</span>
          <span class="section-title-en">Contact</span>
        </h2>
        <p class="contact-intro">欢迎随时与我交流，无论是技术探讨还是闲聊都很乐意。</p>
        <div class="contact-links">
          <a href="https://github.com/Silver-Moon-Over-Snow" class="contact-card" target="_blank" rel="noopener"><span>GitHub</span></a>
          <a href="mailto:jq_li25@stu.pku.edu.cn" class="contact-card"><span>Email</span></a>
        </div>
      </div>
    </section>
  </main>

  <button class="back-to-top" aria-label="回到顶部">⌃</button>

  <section class="signature-band" aria-hidden="true">
    <div class="container signature-band-inner">
      <aside class="scroll-signature">
        <svg class="signature-svg" viewBox="0 0 1015 449" role="img" aria-label="Cheerly signature">
          <defs>
            <mask id="signature-mask-astro" maskUnits="userSpaceOnUse">
              <rect width="1015" height="449" fill="black" />
              <path class="signature-mask-path" d="M420 58 C282 36 66 176 24 319 C-4 416 114 426 239 343 C347 271 428 176 416 82 C405 35 315 70 180 192" />
              <path class="signature-mask-path" d="M294 397 C329 316 418 208 463 135 C484 101 499 113 476 150 C434 215 374 279 352 304 C390 244 434 205 444 228 C458 259 427 294 472 281 C520 268 551 211 511 205 C463 199 460 286 526 278 C583 271 614 214 579 205 C535 192 521 278 591 276 C645 274 671 227 667 190 C660 238 676 271 724 247 C780 219 823 176 839 107 C849 61 813 59 785 118 C749 193 721 293 704 366 C692 419 750 415 790 342 C824 280 846 228 863 189 C855 260 889 291 943 255 C970 238 988 238 1003 250" />
              <path class="signature-mask-path" d="M206 423 C288 336 454 298 676 264" />
              <path class="signature-mask-path" d="M637 117 C658 112 678 119 694 137" />
            </mask>
          </defs>
          <image class="signature-img" href="/images/signature-transparent.png" width="1015" height="449" mask="url(#signature-mask-astro)" />
        </svg>
      </aside>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p class="footer-text">&copy; 2026 Cheerly - Silver-Moon-Over-Snow</p>
      <p class="footer-sub">银月覆雪 · 以代码编织星空</p>
    </div>
  </footer>
</BaseLayout>


