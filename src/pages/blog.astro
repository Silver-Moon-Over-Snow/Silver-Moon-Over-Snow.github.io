---
import BaseLayout from '../layouts/BaseLayout.astro';

const feedItems = [
  {
    title: 'Linear Algebra Practice',
    titleZh: '线性代数练习',
    href: '/linear-algebra-practice/',
    date: '2026',
    description: 'Course-oriented practice materials, refined sources, and problem review.',
    descriptionZh: '课程练习、精校资料与题目回顾，作为学习过程中的整理入口。'
  },
  {
    title: 'Parallel Practice',
    titleZh: '并行程序设计练习',
    href: '/parallel-practice/',
    date: '2026',
    description: 'Parallel programming review materials, cheat sheets, and final exam notes.',
    descriptionZh: '并行程序设计复习材料、速查手册与期末备考笔记。'
  },
  {
    title: 'Personal Academic Site',
    titleZh: '个人学术主页仓库',
    href: 'https://github.com/Silver-Moon-Over-Snow/silver-moon-over-snow.github.io',
    date: '2026',
    description: 'The source repository for this Astro-powered academic homepage.',
    descriptionZh: '这个 Astro 学术主页的源代码仓库与持续迭代记录。'
  }
];
---

<BaseLayout title="Blog - Jiaqi Li" description="Jiaqi Li 的个人动态与学习材料入口。">
  <nav class="nav" aria-label="Blog navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Back to homepage">Cheerly</a>
      <ul class="nav-links">
        <li><a href="/"><span class="lang-en">Home</span><span class="lang-zh">主页</span></a></li>
        <li><a href="/blog/"><span class="lang-en">Blog</span><span class="lang-zh">动态</span></a></li>
        <li><a href="/cv/Jiaqi_Li_CV.pdf" target="_blank" rel="noopener">CV</a></li>
      </ul>
      <button class="lang-toggle" type="button" aria-label="Switch language">
        <span class="lang-option-en">EN</span> / <span class="lang-option-zh">中</span>
      </button>
      <button class="theme-toggle" type="button" aria-label="Toggle dark mode">
        <span class="theme-toggle-icon" aria-hidden="true"></span>
      </button>
    </div>
  </nav>

  <main class="note-page">
    <section class="note-article">
      <p class="eyebrow">
        <span class="lang-en">Personal Blog</span>
        <span class="lang-zh">个人动态</span>
      </p>
      <h1><span class="lang-en">Personal Blog</span><span class="lang-zh">个人动态</span></h1>
      <p class="note-description">
        <span class="lang-en">Small updates and study entrances, kept separate from the formal homepage.</span>
        <span class="lang-zh">一些小更新和学习材料入口，和正式主页正文分开放。</span>
      </p>
      <div class="note-list standalone">
        {feedItems.map((item) => (
          <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined}>
            <span><span class="lang-en">{item.title}</span><span class="lang-zh">{item.titleZh}</span></span>
            <small>
              <span class="lang-en">{item.description} · {item.date}</span>
              <span class="lang-zh">{item.descriptionZh} · {item.date}</span>
            </small>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
